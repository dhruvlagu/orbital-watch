{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron/refresh-satcat",
      "schedule": "12 18 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/spacetrack/satcat",
      "destination": "/api/spacetrack"
    },
    {
      "source": "/api/spacetrack/conjunctions",
      "destination": "/api/conjunctions"
    },
    {
      "source": "/api/spacetrack/representative",
      "destination": "/api/representative"
    },
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|favicon\\.ico|og-image\\.png|apple-touch-icon\\.png|favicon\\.svg).*)",
      "destination": "/index.html"
    }
  ]
}
